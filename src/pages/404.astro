---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header     from '../components/Header.astro';
---
<BaseLayout title="Страница не найдена">
  <Header />
  <main class="e404">
    <span class="e404-code">404</span>
    <h1>Страница не найдена</h1>
    <p>Возможно, она была перемещена или удалена.</p>
    <a href="/" class="btn btn-gold" style="margin-top:2rem">На главную</a>
  </main>
</BaseLayout>
<style>
  .e404 { min-height:100svh; display:flex; flex-direction:column; align-items:center; justify-content:center; text-align:center; gap:1.2rem; padding:2rem; }
  .e404-code { font-family:var(--ff-display); font-size:clamp(6rem,18vw,12rem); font-weight:300; color:var(--accent-lt); line-height:1; }
  h1 { font-family:var(--ff-display); font-weight:300; font-size:clamp(1.5rem,3vw,2.2rem); }
  p  { color:var(--muted); }
</style>
