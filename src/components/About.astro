---
// src/components/About.astro
interface Props { data: any }
const { data: a } = Astro.props;

// Render rich-text nodes to HTML string
function rtToHtml(node: any): string {
  if (!node) return '';
  if (node.type === 'root') return node.children.map(rtToHtml).join('');
  if (node.type === 'p') {
    const inner = node.children.map(rtToHtml).join('');
    return `<p>${inner}</p>`;
  }
  if (node.type === 'text') {
    let t = node.text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    if (node.bold)   t = `<strong>${t}</strong>`;
    if (node.italic) t = `<em>${t}</em>`;
    return t;
  }
  if (node.children) return node.children.map(rtToHtml).join('');
  return '';
}
const bodyHtml = rtToHtml(a.body);
---

<section class="section about-section" id="about">
  <div class="container about-grid">

    <div class="about-label">
      <span class="eyebrow">{a.sectionLabel}</span>
      <span class="label-line" aria-hidden="true"></span>
    </div>

    <div class="about-body">
      <div class="about-text reveal" set:html={bodyHtml} />

      {a.stats?.length > 0 && (
        <div class="about-stats">
          {a.stats.map((s: any) => (
            <div class="stat reveal">
              <span class="stat-value">{s.value}</span>
              <span class="stat-label">{s.label}</span>
            </div>
          ))}
        </div>
      )}
    </div>

  </div>
</section>

<style>
  .about-section {
    background:var(--surface);
    border-top:1px solid rgba(26,21,15,.06);
  }
  .about-grid {
    display:grid;
    grid-template-columns:100px 1fr;
    gap:0 3.5rem;
    align-items:start;
  }
  .about-label {
    display:flex; flex-direction:column; align-items:center; gap:1.2rem;
    padding-top:.4rem;
  }
  .about-label .eyebrow { writing-mode:vertical-rl; transform:rotate(180deg); font-size:.65rem; }
  .label-line {
    display:block; width:1px; flex:1; min-height:60px;
    background:linear-gradient(to bottom, var(--accent-lt), transparent);
  }

  .about-text { margin-bottom:3rem; }
  .about-text :global(p) {
    font-size:1.05rem; color:var(--mid); line-height:1.82;
    max-width:62ch; margin-bottom:1.1rem;
  }
  .about-text :global(p:last-child) { margin-bottom:0; }
  .about-text :global(strong) { color:var(--dark); font-weight:500; }

  .about-stats { display:flex; gap:3rem; flex-wrap:wrap; }
  .stat { display:flex; flex-direction:column; gap:.25rem; }
  .stat-value {
    font-family:var(--ff-display); font-size:3rem; font-weight:300;
    color:var(--accent); line-height:1;
  }
  .stat-label {
    font-size:.72rem; letter-spacing:.12em;
    text-transform:uppercase; color:var(--muted);
  }

  @media(max-width:700px) {
    .about-grid { grid-template-columns:1fr; }
    .about-label { flex-direction:row; align-items:center; margin-bottom:2rem; }
    .about-label .eyebrow { writing-mode:horizontal-tb; transform:none; }
    .label-line { display:none; }
  }
</style>
