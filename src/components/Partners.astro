---
// src/components/Partners.astro
interface Props { data: any }
const { data: p } = Astro.props;
---

<section class="section partners-section" id="partners">
  <div class="container">
    <h2 class="section-heading reveal">{p.heading}</h2>
    <div class="partners-grid">
      {p.items.map((item: any) => (
        <div class="partner-item reveal">
          {item.url
            ? <a href={item.url} target="_blank" rel="noopener">
                {item.logo
                  ? <img src={item.logo} alt={item.name} loading="lazy" />
                  : <span class="partner-name">{item.name}</span>
                }
              </a>
            : item.logo
              ? <img src={item.logo} alt={item.name} loading="lazy" />
              : <span class="partner-name">{item.name}</span>
          }
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .partners-section { background:var(--surface); }
  .partners-grid {
    display:flex; flex-wrap:wrap; gap:2rem; align-items:center; justify-content:center;
  }
  .partner-item {
    width:140px; height:70px;
    display:flex; align-items:center; justify-content:center;
    filter:grayscale(1); opacity:.6; transition:filter .3s, opacity .3s;
  }
  .partner-item:hover { filter:none; opacity:1; }
  .partner-item img { max-width:100%; max-height:100%; object-fit:contain; }
  .partner-name { font-size:.8rem; letter-spacing:.1em; text-transform:uppercase; color:var(--muted); }
</style>
