---
// src/components/Hero.astro
interface Props { data: any }
const { data: h } = Astro.props;
// Split multiline title into lines
const lines = (h.title as string).split('\n');
---

<section class="hero" id="hero">
  <div class="hero-grain" aria-hidden="true"></div>

  <div class="hero-inner container">
    <div class="hero-content">
      <p class="eyebrow reveal">{h.eyebrow}</p>
      <h1 class="hero-title reveal">
        {lines.map((line: string, i: number) => (
          <>
            {i === 0 ? <strong>{line}</strong> : <span>{line}</span>}
            {i < lines.length - 1 && <br />}
          </>
        ))}
      </h1>
      {h.subtitle && <p class="hero-sub reveal">{h.subtitle}</p>}

      <div class="hero-actions reveal">
        <a class="btn btn-gold" href={h.ctaUrl} target="_blank" rel="noopener">{h.ctaLabel}</a>
      </div>

      <div class="hero-socials reveal">
        {h.waUrl && <a href={h.waUrl} target="_blank" rel="noopener">WhatsApp</a>}
        {h.waUrl && h.tgUrl && <span aria-hidden="true">·</span>}
        {h.tgUrl && <a href={h.tgUrl} target="_blank" rel="noopener">Telegram</a>}
      </div>
    </div>

    <aside class="hero-deco" aria-hidden="true">
      <span class="deco-line"></span>
      <span class="deco-label">Interior Design</span>
    </aside>
  </div>

  <div class="scroll-cue" aria-hidden="true">
    <span class="sc-line"></span>
    <span class="sc-txt">Scroll</span>
  </div>
</section>

<style>
  .hero {
    position:relative; min-height:100svh;
    display:flex; align-items:center; overflow:hidden;
    background:var(--bg);
  }
  .hero-grain {
    position:absolute; inset:0; pointer-events:none; z-index:0;
    background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
    background-size:200px;
  }
  .hero-inner {
    position:relative; z-index:1;
    display:flex; align-items:flex-end; justify-content:space-between;
    gap:4rem; padding-top:8rem; padding-bottom:4rem; width:100%;
  }
  .hero-content { max-width:680px; }

  .eyebrow { margin-bottom:1.4rem; }

  .hero-title {
    font-family:var(--ff-display);
    font-weight:300;
    font-size:clamp(2.2rem, 5.5vw, 5rem);
    line-height:1.12;
    letter-spacing:.02em;
    color:var(--dark);
    margin-bottom:1.6rem;
    transition-delay:.1s;
  }
  .hero-title strong { font-weight:600; color:var(--accent); }
  .hero-title span   { font-style:italic; }

  .hero-sub {
    font-family:var(--ff-display);
    font-style:italic;
    font-size:clamp(1rem,1.8vw,1.25rem);
    color:var(--mid);
    max-width:52ch;
    line-height:1.75;
    margin-bottom:2.5rem;
    transition-delay:.2s;
  }
  .hero-actions { margin-bottom:1.8rem; transition-delay:.3s; }
  .hero-socials {
    display:flex; gap:.9rem; align-items:center;
    font-size:.75rem; letter-spacing:.12em; color:var(--muted);
    transition-delay:.4s;
  }
  .hero-socials a {
    color:var(--muted); border-bottom:1px solid transparent;
    transition:color .25s, border-color .25s; padding-bottom:1px;
  }
  .hero-socials a:hover { color:var(--accent); border-color:var(--accent); }

  .hero-deco {
    display:flex; flex-direction:column; align-items:center;
    gap:1rem; padding-bottom:1rem; flex-shrink:0;
  }
  .deco-line  { display:block; width:1px; height:80px; background:linear-gradient(to bottom,transparent,var(--accent-lt)); }
  .deco-label {
    writing-mode:vertical-rl; transform:rotate(180deg);
    font-size:.62rem; letter-spacing:.28em; text-transform:uppercase; color:var(--muted);
  }

  .scroll-cue {
    position:absolute; bottom:2.5rem; left:50%; transform:translateX(-50%);
    display:flex; flex-direction:column; align-items:center; gap:.5rem; z-index:1;
    animation:bob 2.2s ease-in-out infinite;
  }
  .sc-line { display:block; width:1px; height:40px; background:linear-gradient(to bottom,var(--accent),transparent); }
  .sc-txt  { font-size:.58rem; letter-spacing:.3em; text-transform:uppercase; color:var(--muted); }
  @keyframes bob {
    0%,100% { transform:translateX(-50%) translateY(0); }
    50%     { transform:translateX(-50%) translateY(6px); }
  }

  @media(max-width:700px) {
    .hero-deco { display:none; }
    .hero-inner { padding-top:6rem; }
  }
</style>
